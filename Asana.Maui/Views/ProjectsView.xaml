<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Asana.Maui.Views.ProjectsView"
             Title="ProjectsView"
             NavigatedTo="ContentPage_NavigatedTo">
    <VerticalStackLayout>
        <Grid>
            <ListView
                ItemsSource="{Binding Projects}"
                SelectedItem="{Binding SelectedProject}"
                >
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <ViewCell>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="10*"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <Label Text="{Binding Model.Name}" Grid.Row="0"/>
                                    <Label Text="{Binding Model.Description}" Grid.Row="1"/>
                                </Grid>
                                <Label Text="{Binding Model.CompletePercent, StringFormat='{}{0:F0}%'}" Grid.Column="1"/>
                            </Grid>
                        </ViewCell>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
        <Button Text="Add Project" Clicked="AddClicked"/>
        <Button Text="Edit Project" Clicked="EditClicked"/>
        <Button Text="Delete Project" Clicked="DeleteClicked"/>
        <Button Text="Go to Selected Project's ToDo List" Clicked="GoToToDoListClicked"/>
        <Button Text="Cancel" Clicked="CancelClicked"/>
    </VerticalStackLayout>
</ContentPage>